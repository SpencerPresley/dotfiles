{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

echo "==> Setting up Docker Compose CLI plugin..."

if ! command -v brew &> /dev/null; then
    echo "    ERROR: Homebrew not found. Install it first: https://brew.sh" >&2
    exit 1
fi

if [ ! -L "$HOME/.docker/cli-plugins/docker-compose" ]; then
    mkdir -p "$HOME/.docker/cli-plugins"
    ln -sfn /opt/homebrew/bin/docker-compose "$HOME/.docker/cli-plugins/docker-compose"
    echo "    Symlink created."
else
    echo "    Docker Compose CLI plugin already configured."
fi

echo "==> Docker Compose setup complete."
{{- end }}
