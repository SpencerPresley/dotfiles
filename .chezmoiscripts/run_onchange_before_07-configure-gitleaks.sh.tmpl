{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

# Ensure the secret-scanning setup is live on this machine WITHOUT needing a full
# bootstrap / brew bundle:
#   1. install gitleaks if missing
#   2. wire the pre-commit hook in the dotfiles repo (core.hooksPath)
# Without gitleaks present, .githooks/pre-commit silently skips (exit 0), so the
# install is what makes the hook actually protect anything.

echo "==> Ensuring gitleaks + pre-commit hook..."

# 1. install gitleaks if missing
if ! command -v gitleaks >/dev/null 2>&1; then
    if command -v brew >/dev/null 2>&1; then
        echo "    Installing gitleaks..."
        brew install gitleaks
    else
        echo "    brew not found; cannot install gitleaks — skipping."
        exit 0
    fi
else
    echo "    gitleaks already installed ($(gitleaks version 2>/dev/null))."
fi

# 2. wire the hook in the dotfiles source repo (idempotent)
SRC="{{ .chezmoi.sourceDir }}"
if [ -d "$SRC/.git" ] && [ -f "$SRC/.githooks/pre-commit" ]; then
    if [ "$(git -C "$SRC" config core.hooksPath 2>/dev/null || true)" != ".githooks" ]; then
        git -C "$SRC" config core.hooksPath .githooks
        echo "    Wired core.hooksPath -> .githooks"
    else
        echo "    Pre-commit hook already wired."
    fi
fi

echo "==> gitleaks configuration complete."
{{- end }}
