dot_git/
.omc/

# Claude Code runtime artifacts (lock files, etc.). Use .claude/* (not
# .claude/) so the negation works — git won't descend into a dir excluded
# with a trailing slash, which would make the opt-out below a no-op.
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Machine-local Ghostty overrides. Untracked on purpose: fiddle with font/theme
# here without committing, promote to the tracked defaults in config.tmpl only
# when you decide on a new default. chezmoi still reads it (it's .chezmoidata,
# not git) and renders the values inline into ~/.config/ghostty/config — no
# file is placed on the machine.
.chezmoidata/ghostty-local.toml
