font-family = Hack Nerd Font
# Icon-glyph fallback: only consulted for codepoints the primary font lacks.
# Hack NF is a complete Nerd Font, so this is inert today — it exists so a
# future font swap (here or in config.local) can't lose Nerd Font icons.
# See docs/fonts.md in the chezmoi repo for the per-font glyph inventory.
font-family = Symbols Nerd Font Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = 16
font-shaping-break = cursor
theme = Banana Blueberry
cursor-style = block
cursor-style-blink = true
cursor-click-to-move = true
shell-integration = zsh
shell-integration-features = no-cursor,sudo
mouse-hide-while-typing = true
window-title-font-family = JetBrainsMonoNL Nerd Font Mono
macos-option-as-alt = left
auto-update = check
window-padding-x = 4
window-padding-y = 4
copy-on-select = true
window-inherit-working-directory = true
window-inherit-font-size = true
keybind = shift+enter=text:\x1b\r
background-opacity = 1
background-blur = 20
desktop-notifications = true
progress-style = true
link-previews = true

# Per-machine overrides live in ~/.config/ghostty/config.local (unmanaged by
# chezmoi; ? = ignore if missing). Ghostty itself reads it on every config
# load/reload — chezmoi is not involved. It loads after this entire file, so
# scalar values in it win. Gotcha: list options (font-family, keybind,
# palette, …) APPEND to this file's values instead of replacing them — reset
# the list first with an empty value:
#     font-family =
#     font-family = Some Other Font
config-file = ?config.local

