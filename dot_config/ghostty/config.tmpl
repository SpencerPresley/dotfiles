font-family = Hack Nerd Font
# Icon-glyph fallback: only consulted for codepoints the primary font lacks.
# Hack NF is a complete Nerd Font, so this is inert today — it exists so a
# future font swap (here or via a per-machine override) can't lose NF icons.
# See docs/fonts.md in the chezmoi repo for the per-font glyph inventory.
font-family = Symbols Nerd Font Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = 16
font-shaping-break = cursor
theme = Banana Blueberry
cursor-style = block
cursor-style-blink = true
cursor-click-to-move = true
shell-integration = zsh
shell-integration-features = no-cursor,sudo
mouse-hide-while-typing = true
window-title-font-family = JetBrainsMonoNL Nerd Font Mono
macos-option-as-alt = left
auto-update = check
window-padding-x = 4
window-padding-y = 4
copy-on-select = true
window-inherit-working-directory = true
window-inherit-font-size = true
keybind = shift+enter=text:\x1b\r
background-opacity = 1
background-blur = 20
desktop-notifications = true
progress-style = true
link-previews = true

# Per-machine overrides — declared in .chezmoidata/ghostty.yaml keyed by
# hostname and rendered below at chezmoi apply time, so every machine's
# settings stay visible in the repo. Scalars simply override (last value
# wins); YAML-list values get an automatic reset line first, because ghostty
# list options (font-family, keybind, palette, …) append instead of replace.
{{- $overrides := dig .chezmoi.hostname (dict) .ghostty.overrides }}
{{- range $key, $value := $overrides }}
{{- if kindIs "slice" $value }}
{{ $key }} =
{{- range $value }}
{{ $key }} = {{ . }}
{{- end }}
{{- else }}
{{ $key }} = {{ $value }}
{{- end }}
{{- end }}

