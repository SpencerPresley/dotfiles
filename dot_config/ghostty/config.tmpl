font-family = Hack Nerd Font
# Icon-glyph fallback: only consulted for codepoints the primary font lacks.
# Hack NF is a complete Nerd Font, so this is inert today — it exists so a
# future font swap (here or via a per-machine override) can't lose NF icons.
# See docs/fonts.md in the chezmoi repo for the per-font glyph inventory.
font-family = Symbols Nerd Font Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = 16
font-shaping-break = cursor
theme = Banana Blueberry
cursor-style = block
cursor-style-blink = true
cursor-click-to-move = true
shell-integration = zsh
shell-integration-features = no-cursor,sudo
mouse-hide-while-typing = true
window-title-font-family = JetBrainsMonoNL Nerd Font Mono
macos-option-as-alt = left
auto-update = check
window-padding-x = 4
window-padding-y = 4
copy-on-select = true
window-inherit-working-directory = true
window-inherit-font-size = true
keybind = shift+enter=text:\x1b\r
background-opacity = 1
background-blur = 20
desktop-notifications = true
progress-style = true
link-previews = true

# Machine-local overrides. To change font/theme/etc on THIS machine without
# committing, create .chezmoidata/ghostty-local.toml (gitignored — see the repo
# .gitignore) with a [ghostty.local] table. chezmoi merges it into template data
# and renders the values inline BELOW at apply time; nothing is placed on the
# machine, and ~/.config/ghostty/config stays the single source. Example:
#
#   [ghostty.local]
#   font-size = 17
#   theme = "Dracula"
#   font-family = ["Monaspace Neon", "Symbols Nerd Font Mono"]
#
# Scalars override (ghostty last-value-wins). List values (font-family, keybind,
# palette, …) emit a reset line first, because ghostty appends to list options
# rather than replacing — so a font-family override must re-list Symbols Nerd
# Font Mono or you lose icon glyphs. Promote a value to the tracked default by
# editing the plain lines above and committing.
{{- $local := dig "ghostty" "local" (dict) . }}
{{- range $key, $value := $local }}
{{- if kindIs "slice" $value }}
{{ $key }} =
{{- range $value }}
{{ $key }} = {{ . }}
{{- end }}
{{- else }}
{{ $key }} = {{ $value }}
{{- end }}
{{- end }}

