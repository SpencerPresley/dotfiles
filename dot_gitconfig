# delta: syntax-highlighting pager for diff/show/log -p/blame
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true       # n/N to jump between files in a diff
	line-numbers = true
[merge]
	conflictstyle = zdiff3 # clearer 3-way conflict markers (git >= 2.35)
[diff]
	colorMoved = default
