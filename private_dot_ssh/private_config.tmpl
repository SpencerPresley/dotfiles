# Managed by chezmoi. Edit the source, not this file:
#   chezmoi edit ~/.ssh/config   (then: chezmoi apply)
#
# All private keys live in 1Password and are served by its SSH agent (see the
# Host * IdentityAgent line). Only the *public* keys live on disk; each Host
# pins its key via `IdentityFile <pubkey>` + `IdentitiesOnly yes`, which makes
# ssh ask the agent for the matching private key. No private key files needed.

# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Include ~/.colima/ssh_config

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# --- GitHub: personal ---
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519.pub
  IdentitiesOnly yes

# --- GitHub: work (crunchatlas) ---
Host github-work
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_work.pub
  IdentitiesOnly yes

# --- AtlasConnect EC2 ---
Host atlasconnect-ec2
  HostName {{ onepasswordRead "op://Personal/ac-ec2-public-ip/credential" }}
  User ubuntu
  IdentityFile ~/.ssh/atlasconnect-key.pub
  IdentitiesOnly yes

# --- crunchbox-lab (Tailscale) ---
Host crunchbox-lab
  HostName {{ onepasswordRead "op://Personal/crunchbox-lab-host/credential" }}
  User crunchadmin
  IdentityFile ~/.ssh/id_ed25519.pub
  IdentitiesOnly yes
  ServerAliveInterval 60
  ServerAliveCountMax 3

# --- ph-demo-box ---
Host ph-demo-box-root
  HostName {{ onepasswordRead "op://Personal/ph-demo-box-ip/credential" }}
  User root
  IdentityFile ~/.ssh/ph-demo-box.pub
  IdentitiesOnly yes

Host ph-demo-box-ubuntu
  HostName {{ onepasswordRead "op://Personal/ph-demo-box-ip/credential" }}
  User ubuntu
  IdentityFile ~/.ssh/ph-demo-box.pub
  IdentitiesOnly yes

# --- AtlasCyber prod backend box "beast" (via reverse-proxy bastion) ---
# beast has no public IP; its SSH is exposed as localhost:22000 on the
# atlascyber-reverse-proxy EC2 bastion via a reverse tunnel. ProxyJump hops
# through the bastion. Both hops authenticate with id_ed25519 (served by the
# 1Password agent). `ssh atlascyber-backend` lands on beast as user atlascyber.
Host atlascyber-reverse-proxy
  HostName {{ onepasswordRead "op://Personal/atlascyber-reverse-proxy-ip/credential" }}
  User ec2-user
  IdentityFile ~/.ssh/id_ed25519.pub
  IdentitiesOnly yes

Host atlascyber-backend
  HostName localhost
  Port 22000
  User atlascyber
  ProxyJump atlascyber-reverse-proxy
  IdentityFile ~/.ssh/id_ed25519.pub
  IdentitiesOnly yes
  HostKeyAlias beast-reverse-tunnel
  StrictHostKeyChecking accept-new

# --- Industrial Defender IDC sensor (PCAP source for the CrunchAtlas/ID integration) ---
# Appliance with a custom ID CLI: `exec bash` opens a shell (root password). Capture PCAPs
# from the CLI with `exec tcpdump`; replay with `exec pcap_replay <file>`. Password auth only
# (no pubkey login on the appliance). Creds in 1Password ("Industrial Defender — IDC" /
# "— IDCM"); host IPs, the IDCM web-UI URL, and the whitelisted-egress-IP caveat live in
# the private runbook tracker/industrial-defender/idc-environment-access.md — not here (public repo).
Host idc
  HostName {{ onepasswordRead "op://Personal/idc-ip/credential" }}
  User admin
  PubkeyAuthentication no
  PreferredAuthentications password,keyboard-interactive
  ServerAliveInterval 30
  ServerAliveCountMax 3
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m
