# Purple Haze Backend - Local Dev Environment

# Database
DATABASE_ENGINE=django.db.backends.postgresql_psycopg2
DATABASE_HOST=localhost
DATABASE_NAME=atlascyber
DATABASE_USER=postgres
DATABASE_PORT=5432
DATABASE_PASSWORD=postgres

# LLM - ClemAI
DISABLE_CLEMLLM=False
LLM_ENDPOINT=http://host.docker.internal:5001/query
LLM_USERNAME=admin
LLM_PASSWORD=newnorth

# Frontend
ALLOWED_ORIGIN=http://localhost:5173
ALLOWED_LOCAL='http://localhost:5173'
ENVIRONMENT=development

# Bazze - disabled
DISABLE_BAZZE=True
BAZZE_API_KEY=placeholder

# Processing
PACKET_PROCESSING_CHUNK_SIZE=25000
NUMBER_CPU_WORKERS=12

# IP API
IPAPI_IS_KEY=key

# Redis
REDIS_HOST=redis://:redis@localhost:6379/0
REDIS_PASSWORD=redis

# Datalake
DATALAKE_HOST=http://localhost:8001
DATALAKE_API_KEY=key

# Graphite (AppS for Apple Silicon)
GRAPHITE_PATH=AppS

# Industrial Defender - disabled
DISABLE_INDUSTRIAL_DEFENDER_INGESTION=True
INDUSTRIAL_DEFENDER_ENDPOINT=
INDUSTRIAL_DEFENDER_SECRET=
INDUSTRIAL_DEFENDER_CLIENT_ID=
INDUSTRIAL_DEFENDER_ANALYST_EMAIL=

# Download token
DOWNLOAD_TOKEN_MAX_AGE=3600

# Email - MailHog
EMAIL_HOST=host.docker.internal
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@atlascyber.com

# Threat reports
SEND_THREAT_REPORT=True
RANDOM_CASE_REPORT_DAYS=7
RANDOM_CASE_REPORT_INTERVAL_DAYS=3

# Metasploit (for --profile pentest)
MSF_DB_PASSWORD=msfpassword
MSF_RPC_PASSWORD=changeme
